From 7a3da571b09ea32f02b749fe0aa935fd760d9744 Mon Sep 17 00:00:00 2001
From: GrecAndrei <alex092lap@duck.com>
Date: Wed, 22 Apr 2026 22:07:47 +0300
Subject: [PATCH 6/6] arm64: dts: allwinner: Add sun60i-a733 generated drivers
 and bindings

Add generated CCU drivers (main, R, RTC, CPUPLL), pinctrl driver,
base DTSI, board DTS, and all dt-bindings headers.

Signed-off-by: GrecAndrei <alex092lap@duck.com>
---
 .../allwinner/sun60i-a733-orangepi-4-pro.dts  |   53 +
 .../arm64/boot/dts/allwinner/sun60i-a733.dtsi |  598 +++++
 drivers/clk/sunxi-ng/ccu-sun60i-a733-cpupll.c |  178 ++
 drivers/clk/sunxi-ng/ccu-sun60i-a733-r.c      |  246 ++
 drivers/clk/sunxi-ng/ccu-sun60i-a733-rtc.c    |  250 ++
 drivers/clk/sunxi-ng/ccu-sun60i-a733.c        | 2205 +++++++++++++++++
 include/dt-bindings/clock/sun60i-a733-ccu.h   |  327 +++
 .../clock/sun60i-a733-cpupll-ccu.h            |   15 +
 include/dt-bindings/clock/sun60i-a733-r-ccu.h |   44 +
 include/dt-bindings/clock/sun60i-a733-rtc.h   |   21 +
 include/dt-bindings/power/sun60i-a733-power.h |   17 +
 include/dt-bindings/reset/sun60i-a733-ccu.h   |  126 +
 include/dt-bindings/reset/sun60i-a733-r-ccu.h |   20 +
 13 files changed, 4100 insertions(+)
 create mode 100644 arch/arm64/boot/dts/allwinner/sun60i-a733-orangepi-4-pro.dts
 create mode 100644 arch/arm64/boot/dts/allwinner/sun60i-a733.dtsi
 create mode 100644 drivers/clk/sunxi-ng/ccu-sun60i-a733-cpupll.c
 create mode 100644 drivers/clk/sunxi-ng/ccu-sun60i-a733-r.c
 create mode 100644 drivers/clk/sunxi-ng/ccu-sun60i-a733-rtc.c
 create mode 100644 drivers/clk/sunxi-ng/ccu-sun60i-a733.c
 create mode 100644 include/dt-bindings/clock/sun60i-a733-ccu.h
 create mode 100644 include/dt-bindings/clock/sun60i-a733-cpupll-ccu.h
 create mode 100644 include/dt-bindings/clock/sun60i-a733-r-ccu.h
 create mode 100644 include/dt-bindings/clock/sun60i-a733-rtc.h
 create mode 100644 include/dt-bindings/power/sun60i-a733-power.h
